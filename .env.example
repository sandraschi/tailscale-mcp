# Copy to .env in this directory and fill in values. (.env is gitignored.)

# -----------------------------------------------------------------------------
# Tailscale Admin API (required for real device/network operations)
# -----------------------------------------------------------------------------
TAILSCALE_API_KEY=your_tailscale_api_key_here
TAILSCALE_TAILNET=your_tailnet_name_here

# -----------------------------------------------------------------------------
# MCP HTTP transport (optional — defaults suit local IDE + webapp backend)
# See src/tailscalemcp/transport.py
# -----------------------------------------------------------------------------
# MCP_TRANSPORT=stdio
# MCP_TRANSPORT=http
# MCP_HOST=127.0.0.1
# MCP_PORT=10821
# MCP_PATH=/mcp

# -----------------------------------------------------------------------------
# SEP-1577 sampling + webapp Local chat / LLM health (optional)
# OpenAI-compatible endpoint; local Ollama usually needs no API key.
# -----------------------------------------------------------------------------
TAILSCALE_SAMPLING_BASE_URL=http://127.0.0.1:11434/v1
TAILSCALE_SAMPLING_MODEL=llama3.2
# TAILSCALE_SAMPLING_API_KEY=
# 1/true/yes = MCP host does sampling; server handler is fallback only
# TAILSCALE_SAMPLING_USE_CLIENT_LLM=1

# -----------------------------------------------------------------------------
# MCP Bridge: comma-separated URLs of remote MCP servers to proxy
# MCP_BRIDGE_URLS=http://127.0.0.1:10821/mcp,http://127.0.0.1:10823/mcp

# -----------------------------------------------------------------------------
# App / config (optional)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
API_TIMEOUT=30.0
PROMETHEUS_PORT=9091
# Seconds — device "online" heuristic (AdvancedDeviceManager)
# TAILSCALE_ONLINE_TIMEOUT_SECONDS=3600

# -----------------------------------------------------------------------------
# Web dashboard (Vite) — put these in web_sota/.env (not here), e.g.:
# VITE_API_URL=http://127.0.0.1:10821
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Grafana / monitoring stack (optional — if you use bundled compose / RebootX)
# -----------------------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=admin
REBOOTX_API_KEY=tailscale-mcp-rebootx-key-2024
REBOOTX_PATH_PREFIX=tailscale-mcp
REBOOTX_EXTERNAL_IP=213.47.34.131
GRAFANA_PORT=3000
PROMETHEUS_PORT_EXTERNAL=9090
LOKI_PORT=3100
REBOOTX_API_PORT=9001
REBOOTX_SWAGGER_PORT=9002
